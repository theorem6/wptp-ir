{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/theorem6/wptp-ir/schema/ir-v0.schema.json",
  "title": "WPTP IR document v0",
  "type": "object",
  "required": ["schemaVersion", "meta", "roots", "nodes", "losses"],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "meta": {
      "type": "object",
      "required": ["sourceApp", "importedFrom"],
      "properties": {
        "sourceApp": { "type": "string" },
        "importedFrom": { "type": "string" },
        "chrysalisVersion": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "additionalProperties": true
    },
    "roots": { "type": "array", "items": { "type": "string" } },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "layer", "op", "valueType", "effects", "operandIds", "attrs", "provenance"],
        "properties": {
          "id": { "type": "string" },
          "layer": { "enum": ["request", "effect", "value"] },
          "op": { "type": "string" },
          "valueType": {},
          "effects": { "type": "array" },
          "operandIds": { "type": "array", "items": { "type": "string" } },
          "attrs": { "type": "object" },
          "provenance": { "type": "array" },
          "webir": {
            "type": "object",
            "properties": {
              "dialect": { "type": "string" },
              "op": { "type": "string" },
              "nodeId": { "type": "string" }
            }
          }
        }
      }
    },
    "losses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["webirNodeId", "dialect", "op", "category", "reason"],
        "properties": {
          "webirNodeId": { "type": "string" },
          "dialect": { "type": "string" },
          "op": { "type": "string" },
          "category": {
            "enum": ["unsupported-dialect", "unsupported-op", "missing-operand", "other"]
          },
          "reason": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
